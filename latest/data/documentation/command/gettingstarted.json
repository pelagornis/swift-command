{"primaryContentSections":[{"content":[{"level":2,"text":"Installation","type":"heading","anchor":"Installation"},{"inlineContent":[{"text":"Command was deployed as Swift Package Manager. Package to install in a project. Add as a dependent item within the swift manifest.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let package = Package(","    ...","    dependencies: [","        .package(url: \"https:\/\/github.com\/pelagornis\/swift-command\", from: \"1.3.0\")","    ],","    ...",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then import the Command from thr location you want to use."}]},{"code":["import Command"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Using Command","type":"heading","anchor":"Using-Command"},{"inlineContent":[{"type":"text","text":"Command offers the most commonly used "},{"code":"bash","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"zsh","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"make"},{"text":", which in addition helps users scale easily.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you want to use Bash.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Command(\\.bash) var bashCommand","bashCommand.run(\"command\")"]},{"inlineContent":[{"type":"text","text":"Or if you want to use zsh."}],"type":"paragraph"},{"code":["@Command(\\.zsh) var zshCommand","zshCommand.run(\"command\")"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or if you want to use Makefile command."}]},{"syntax":"swift","code":["@Command(\\.make) var makeCommand","makeCommand.run(\"command\")"],"type":"codeListing"},{"type":"heading","text":"Extension","anchor":"Extension","level":3},{"inlineContent":[{"type":"text","text":"Command is easier to scale."}],"type":"paragraph"},{"syntax":"swift","code":["extension CommandValues {","    var swift: Al